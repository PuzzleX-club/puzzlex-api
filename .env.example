# PuzzleX Backend — Environment Variables
#
# Copy this file to .env and fill in the values for your environment.
# Use placeholder/example values only — never commit real secrets.

# === Quick Start (OSS example mode) ===
# Uncomment the following to run with bundled example data.
# No external API, repo sync, blockchain indexer, or private dependencies needed.
#
# CATALOG_PROVIDER=example
# INSTANCE_METADATA_PROVIDER=example
# INSTANCE_METADATA_ENABLED=true

# === Required ===

# Database connection (PostgreSQL)
# DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/puzzlex_dev

# Redis (cache + Sidekiq queue)
# REDIS_URL=redis://127.0.0.1:6379/0

# === Rails ===

# JWT signing secret for authentication tokens.
# Required in production. Falls back to SECRET_KEY_BASE if not set.
# AUTH_JWT_SECRET=your-secret-key-here

# RAILS_LOG_LEVEL=info
# RAILS_DEVELOPMENT_HOSTS=localhost
# DEFAULT_PROJECT_KEY=default
#
# Internal/test-only toggles such as ADMIN_SKIP_AUTH, ASYNC_JOBS,
# INTEGRATION_TEST_API_* and CI helpers are intentionally omitted here.
# They are not part of the public OSS config surface.

# === Production Hosts / CORS ===
# Comma-separated list of allowed hosts and Action Cable origins (production only)
# ACTION_CABLE_URL=wss://your-domain.com/cable
# ACTION_CABLE_ALLOWED_ORIGINS=https://your-domain.com
# ALLOWED_HOSTS=your-domain.com
# GATEWAY_MARKET_SERVER_URL=http://localhost:3000/api/market
# GATEWAY_ORDER_SERVICE_URL=http://localhost:3000/api/order
# GATEWAY_USER_SERVICE_URL=http://localhost:3000/api/user

# === Blockchain / Contracts ===

# RPC endpoint for the target chain (Anvil for local dev, default: http://127.0.0.1:8546)
# BLOCKCHAIN_RPC_URL=http://127.0.0.1:8546
# CHAIN_ID=31338

# Contract addresses (CREATE2 deterministic addresses for local dev)
# SEAPORT_CONTRACT_ADDRESS=0x...
# NFT_CONTRACT_ADDRESS=0x...
# ERC20_CONTRACT_ADDRESS=0x...
# ZONE_CONTRACT_ADDRESS=0x...
# PLATFORM_CONTRACT_ADDRESS=0x...
# ROYALTY_CONTRACT_ADDRESS=0x...
# ALLOWED_ZONE_MANAGER_ADDRESS=0x...
# CONDUIT_CONTROLLER_ADDRESS=0x...

# Block number to start listening for on-chain events (0 for local dev)
# EVENT_LISTENER_GENESIS_BLOCK=0

# Token ID parser strategy shared with frontend.
# embedded = current PuzzleX/Lumi-style {prefix}{itemId}{quality} parser
# identity = treat tokenId itself as itemId
# custom   = project-supplied adapter (see app/services/blockchain/custom_token_id_parser.rb)
# TOKEN_ID_PARSER_MODE=embedded
# TOKEN_ID_PARSER_EMBEDDED_PREFIX=0x10
# TOKEN_ID_PARSER_ERC20_PREFIX=0x20
# TOKEN_ID_PARSER_HASH_BYTES=16
# TOKEN_ID_PARSER_QUALITY_BYTES=1

# === Matching Engine ===

# Spread allocation (basis points, total must = 10000)
# MATCH_SPREAD_PLATFORM_BPS=5000
# MATCH_SPREAD_ROYALTY_BPS=900
# MATCH_SPREAD_SELLER_BPS=0

# Matching scheduler tuning
# MATCH_ENGINE_MXN_ENABLED=true
# CES_MAX_LAYERS=5
# CES_MAX_TARGETS=8
# CES_FLOW_BUDGET=20
# CES_ROUND_TIMEOUT_MS=500
# CES_MAX_BITSET_SIZE=10000
# CES_WINDOW_SIZE=150
# CES_MAX_ROUNDS=10
# CES_TOTAL_TIMEOUT_MS=3000
# MATCH_SCHEDULER_WORKER_TIMEOUT_SEC=10
# MATCH_SCHEDULER_LOCK_TTL_SEC=15
# MATCH_SCHEDULER_LOOP_BUDGET_SEC=5
# MATCH_SCHEDULER_FOLLOWUP_DELAY_SEC=1
# MATCH_SCHEDULER_WAITING_DELAY_SEC=10
# MATCH_SCHEDULER_DEDUP_TTL_SEC=2

# Matching log noise control
# MATCH_LOGGING_ENABLED=true
# MATCH_LOGGING_PERSIST_STARTED=false
# MATCH_LOGGING_STORE_ORDER_HASHES=false
# MATCH_LOGGING_MAX_ORDER_HASHES=6
# MATCH_LOGGING_MAX_QUEUE_OPERATIONS=80
# MATCH_LOGGING_CANCELLED_NOOP_SAMPLING_RATE=0.02

# Zone validation policy
# ZONE_PLATFORM_FEE_PERCENTAGE=200
# ZONE_ROYALTY_FEE_PERCENTAGE=250
# ZONE_PLATFORM_FEE_RECIPIENT=0x0000000000000000000000000000000000000000
# ZONE_ROYALTY_FEE_RECIPIENT=0x0000000000000000000000000000000000000000
# ZONE_SPECIFIED_ERC20_TOKENS=
# ZONE_SPECIFIED_ADDRESSES=

# Canonical matching jobs:
# - Jobs::Matching::DispatcherJob
# - Jobs::Matching::Worker
# - Jobs::Matching::RecoveryJob
# - Jobs::Matching::TimeoutJob
# - Jobs::Matching::OverMatchDispatchJob
# - Jobs::Matching::FailureHandlerJob
# - Jobs::Matching::PausedRecoveryJob

# === Instance Metadata Provider ===
# Provides metadata for NFT token instances (name, description, image, attributes).
# Pipeline: InstanceMetadataFetchJob → ProviderRegistry.current.fetch() → persistence
# See: config/initializers/instance_metadata.rb
#
# Provider type: api / example / none
#   api     — fetches metadata via HTTP from INSTANCE_METADATA_API_BASE_URL
#   example — reads static JSON fixtures from examples/instance_metadata/
#   none    — disabled, no metadata fetching
#
# INSTANCE_METADATA_PROVIDER=api
# INSTANCE_METADATA_ENABLED=true
# INSTANCE_METADATA_API_BASE_URL=https://your-metadata-api.example.com

# Batch and rate-limit tuning
# INSTANCE_METADATA_BATCH_SIZE=200
# INSTANCE_METADATA_BATCH_SIZE_MIN=10
# INSTANCE_METADATA_BATCH_SIZE_STEP=50
# INSTANCE_METADATA_RATE_LIMIT_COOLDOWN=60
# INSTANCE_METADATA_RECOVERY_THRESHOLD=10
# INSTANCE_METADATA_SIMPLE_RATE_LIMIT=false
# INSTANCE_METADATA_EMPTY_AS_RATE_LIMIT=false
# INSTANCE_METADATA_RETRY_LIMIT=3
# INSTANCE_METADATA_FETCH_INTERVAL=1
# INSTANCE_METADATA_SCANNER_QUEUE_THRESHOLD=500

# === Catalog Provider ===
# Provides static catalog data (items, recipes, translations).
# See: config/initializers/catalog_provider.rb
#
# Provider type: repo_sync / example / none
#   repo_sync — syncs from a GitHub CSV repo (requires CATALOG_REPO_SYNC_* config)
#   example   — reads static JSON fixtures from examples/catalog/
#   none      — disabled, no catalog data
#
# Providers declare capabilities that control which features are available:
#   marketplace — enables sellable check on market creation
#   minting     — enables can_mint field
#   recipes     — enables recipe API endpoints and sync
#
# Project-specific item fields go into extra_data JSONB.
# The provider's capabilities[:extension_fields] whitelist controls
# which extra_data keys are exposed in the public API advance envelope.
#
# CATALOG_PROVIDER=repo_sync
# CATALOG_REPO_SYNC_ENABLED=false
# CATALOG_REPO_SYNC_REPO=your-org/shared-data-repo
# CATALOG_REPO_SYNC_BRANCH=main
# CATALOG_REPO_SYNC_SUPPORTED_LANGUAGES=zh-CN,en
# CATALOG_REPO_SYNC_DATA_DIR=data/shared
# CATALOG_REPO_SYNC_ITEM_FILENAME=Item.csv
# CATALOG_REPO_SYNC_RECIPES_FILENAME=Recipes.csv
# CATALOG_REPO_SYNC_TIMEOUT=60
# CATALOG_REPO_SYNC_LOCK_TTL=300
# CATALOG_REPO_SYNC_DEBUG=false
# CATALOG_REPO_SYNC_GITHUB_TOKEN=
# CATALOG_REPO_SYNC_ENABLE_NOTIFICATIONS=false

# === On-chain Indexer ===
# Indexes NFT transfer events and schedules instance metadata fetch work.
# Example mode does not require this section.

# INDEXER_CONTRACT_ADDRESS=0x...
# INDEXER_START_BLOCK=0
# INDEXER_RPC_ENDPOINT=https://rpc.example.invalid
# INDEXER_BLOCK_BATCH_SIZE=90
# INDEXER_POLLING_INTERVAL=5

# Canonical indexer jobs:
# - Jobs::Indexer::EventCollectorJob
# - Jobs::Indexer::EventConsumptionJob
# - Jobs::Indexer::InstanceMetadataScannerJob
# - Jobs::Indexer::InstanceMetadataFetchJob
# - Jobs::Indexer::InstanceMetadataRecoveryJob

# === Event Collector (on-chain event pipeline) ===

# LOG_COLLECTOR_RETENTION_DAYS=30
# LOG_COLLECTOR_RPS=5
# LOG_COLLECTOR_ERROR_BACKOFF_MAX=30
# LOG_COLLECTOR_MAX_CONSECUTIVE_FAILURES=10
# LOG_COLLECTOR_CATCHUP_THRESHOLD=1000
# LOG_COLLECTOR_CATCHUP_RPS=10
# LOG_COLLECTOR_ORDER_EVENTS_ENABLED=true
# Toggle the instance-indexer subscription inside the collector pipeline.
# LOG_COLLECTOR_ITEM_INDEXER_ENABLED=true

# === Sidekiq Leader Election ===

# SIDEKIQ_ELECTION_ENABLED=false
# SIDEKIQ_ELECTION_HEARTBEAT_INTERVAL=10
# SIDEKIQ_ELECTION_HEARTBEAT_JITTER=2
# SIDEKIQ_ELECTION_TTL_SECONDS=60
# SIDEKIQ_ELECTION_MAX_FAILURES=5
# SIDEKIQ_ELECTION_LOG_LEVEL=info
# SIDEKIQ_ELECTION_MONITORING_ENABLED=true
# SIDEKIQ_STATIC_LEADER_INDEX=0

# Watchdog (stale leader detection)
# SIDEKIQ_WATCHDOG_ENABLED=true
# SIDEKIQ_WATCHDOG_CHECK_INTERVAL=20
# SIDEKIQ_WATCHDOG_CHECK_JITTER=3
# SIDEKIQ_WATCHDOG_ACQUIRE_JITTER=5
# SIDEKIQ_WATCHDOG_STALE_THRESHOLD=30
